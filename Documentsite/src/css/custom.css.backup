/**
 * ツールの使い方サイト用カスタムスタイル
 * Infima CSS フレームワークをベースにカスタマイズ
 */

/* You can override the default Infima variables here. */
:root {
  /* 荒サーバー用ダークテーマ - ブラック＆レッド */
  --ifm-color-primary: #dc2626;
  --ifm-color-primary-dark: #b91c1c;
  --ifm-color-primary-darker: #991b1b;
  --ifm-color-primary-darkest: #7f1d1d;
  --ifm-color-primary-light: #ef4444;
  --ifm-color-primary-lighter: #f87171;
  --ifm-color-primary-lightest: #fca5a5;
  --ifm-code-font-size: 95%;
  --docusaurus-highlighted-code-line-bg: rgba(220, 38, 38, 0.1);
  
  /* 荒サーバー用カラーパレット */
  --danger-red: #dc2626;
  --blood-red: #991b1b;
  --dark-gray: #1f2937;
  --darker-gray: #111827;
  --light-gray: #6b7280;
  --warning-orange: #f59e0b;
  --toxic-green: #10b981;
  
  /* ダークテーマの基本色を上書き */
  --ifm-background-color: #0a0a0a;
  --ifm-color-content: #e5e7eb;
  --ifm-color-content-secondary: #9ca3af;
  
  /* カスタムフォント設定 */
  --ifm-font-family-base: 'SF Mono', Monaco, 'Inconsolata', 'Roboto Mono', 
                          'Source Code Pro', monospace;
}

/* For readability concerns, you should choose a lighter palette in dark mode. */
[data-theme='dark'] {
  --ifm-color-primary: #ef4444;
  --ifm-color-primary-dark: #dc2626;
  --ifm-color-primary-darker: #b91c1c;
  --ifm-color-primary-darkest: #991b1b;
  --ifm-color-primary-light: #f87171;
  --ifm-color-primary-lighter: #fca5a5;
  --ifm-color-primary-lightest: #fee2e2;
  --docusaurus-highlighted-code-line-bg: rgba(220, 38, 38, 0.2);
  
  /* ダークテーマ用背景色 */
  --ifm-background-color: #000000;
  --ifm-background-surface-color: #111111;
}

/* カスタムスタイル */
.hero__title {
  font-weight: 700;
  letter-spacing: -0.02em;
  animation: neonGlow 2s infinite;
  background: linear-gradient(45deg, var(--neon-pink), var(--neon-cyan), var(--neon-yellow), var(--neon-green));
  background-size: 400% 400%;
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  position: relative;
}

.hero__title::before {
  content: '';
  position: absolute;
  top: -10px;
  left: -10px;
  right: -10px;
  bottom: -10px;
  background: linear-gradient(45deg, var(--neon-pink), var(--neon-cyan), var(--neon-yellow), var(--neon-green));
  border-radius: 10px;
  z-index: -1;
  animation: sparkle 3s infinite;
  opacity: 0.3;
}

.hero__subtitle {
  font-size: 1.2rem;
  margin: 1rem 0;
  color: var(--neon-cyan);
  text-shadow: 0 0 10px var(--neon-cyan);
  animation: neonGlow 3s infinite reverse;
}

/* ボタンスタイルの改善 */
.button--outline {
  border-width: 2px;
}

/* コードブロックの改善 */
.prism-code {
  font-size: 0.9rem;
  line-height: 1.5;
  border: 2px solid var(--neon-green);
  border-radius: 10px;
  box-shadow: 0 0 20px rgba(0,255,0,0.3);
  background: linear-gradient(135deg, rgba(0,0,0,0.8), rgba(255,0,255,0.1));
}

/* アドモニション（注意書きボックス）のスタイル改善 */
.admonition {
  border-radius: 15px;
  border: 2px solid var(--neon-yellow);
  box-shadow: 0 0 25px rgba(255,255,0,0.4);
  background: linear-gradient(135deg, rgba(255,255,0,0.1), rgba(255,0,255,0.1));
  animation: rainbowBorder 5s infinite;
}

/* ギラギラアニメーション効果 */
@keyframes neonGlow {
  0% { text-shadow: 0 0 5px var(--neon-pink), 0 0 10px var(--neon-pink), 0 0 15px var(--neon-pink); }
  25% { text-shadow: 0 0 5px var(--neon-cyan), 0 0 10px var(--neon-cyan), 0 0 15px var(--neon-cyan); }
  50% { text-shadow: 0 0 5px var(--neon-yellow), 0 0 10px var(--neon-yellow), 0 0 15px var(--neon-yellow); }
  75% { text-shadow: 0 0 5px var(--neon-green), 0 0 10px var(--neon-green), 0 0 15px var(--neon-green); }
  100% { text-shadow: 0 0 5px var(--neon-pink), 0 0 10px var(--neon-pink), 0 0 15px var(--neon-pink); }
}

@keyframes rainbowBorder {
  0% { border-color: var(--neon-pink); box-shadow: 0 0 20px var(--neon-pink); }
  25% { border-color: var(--neon-cyan); box-shadow: 0 0 20px var(--neon-cyan); }
  50% { border-color: var(--neon-yellow); box-shadow: 0 0 20px var(--neon-yellow); }
  75% { border-color: var(--neon-green); box-shadow: 0 0 20px var(--neon-green); }
  100% { border-color: var(--neon-pink); box-shadow: 0 0 20px var(--neon-pink); }
}

@keyframes sparkle {
  0%, 100% { transform: scale(1) rotate(0deg); opacity: 1; }
  50% { transform: scale(1.2) rotate(180deg); opacity: 0.8; }
}

/* ギラギラボタン */
.button {
  background: linear-gradient(45deg, var(--neon-pink), var(--electric-purple), var(--hot-pink));
  background-size: 400% 400%;
  border: 2px solid transparent;
  border-radius: 25px;
  color: white;
  font-weight: bold;
  text-transform: uppercase;
  letter-spacing: 1px;
  transition: all 0.3s ease;
  animation: rainbowBorder 4s infinite;
  position: relative;
  overflow: hidden;
}

.button::before {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255,255,255,0.4), transparent);
  transition: left 0.5s;
}

.button:hover::before {
  left: 100%;
}

.button:hover {
  transform: scale(1.05);
  box-shadow: 0 0 30px var(--neon-pink);
}

/* ギラギラナビゲーションバー */
.navbar {
  background: linear-gradient(90deg, rgba(255,0,255,0.1), rgba(0,255,255,0.1), rgba(255,255,0,0.1));
  border-bottom: 2px solid var(--neon-pink);
  box-shadow: 0 2px 20px rgba(255,0,255,0.3);
}

.navbar__brand:hover {
  animation: sparkle 1s ease-in-out;
}

/* ギラギラサイドバー */
.theme-doc-sidebar-container {
  border-right: 2px solid var(--neon-cyan);
  box-shadow: 2px 0 20px rgba(0,255,255,0.2);
}

.menu__link {
  transition: all 0.3s ease;
}

.menu__link:hover {
  background: linear-gradient(45deg, rgba(255,0,255,0.2), rgba(0,255,255,0.2));
  color: var(--neon-pink);
  text-shadow: 0 0 5px var(--neon-pink);
  transform: translateX(5px);
}

.menu__link--active {
  background: linear-gradient(45deg, var(--neon-pink), var(--electric-purple));
  color: white;
  font-weight: bold;
  animation: neonGlow 2s infinite;
}

/* ギラギラカード効果 */
.card {
  background: linear-gradient(135deg, rgba(255,0,255,0.1), rgba(0,255,255,0.1));
  border: 2px solid var(--neon-pink);
  border-radius: 15px;
  transition: all 0.3s ease;
  box-shadow: 0 5px 20px rgba(255,0,255,0.3);
}

.card:hover {
  transform: translateY(-10px) scale(1.02);
  box-shadow: 0 15px 40px rgba(255,0,255,0.5);
  animation: sparkle 1s ease-in-out;
}

/* ギラギラテーブル */
table {
  border: 2px solid var(--neon-cyan);
  border-radius: 10px;
  overflow: hidden;
  box-shadow: 0 0 20px rgba(0,255,255,0.3);
}

th {
  background: linear-gradient(45deg, var(--neon-pink), var(--electric-purple));
  color: white;
  text-shadow: 0 0 5px white;
}

tr:hover {
  background: linear-gradient(90deg, rgba(255,0,255,0.1), rgba(0,255,255,0.1));
}

/* スクロールバーのカスタマイズ */
::-webkit-scrollbar {
  width: 12px;
}

::-webkit-scrollbar-track {
  background: linear-gradient(180deg, rgba(255,0,255,0.1), rgba(0,255,255,0.1));
}

::-webkit-scrollbar-thumb {
  background: linear-gradient(180deg, var(--neon-pink), var(--neon-cyan));
  border-radius: 10px;
  box-shadow: 0 0 10px rgba(255,0,255,0.5);
}

::-webkit-scrollbar-thumb:hover {
  background: linear-gradient(180deg, var(--neon-cyan), var(--neon-yellow));
  animation: sparkle 1s ease-in-out;
}

/* ページ全体の背景にギラギラ効果 */
body {
  background: linear-gradient(-45deg, #0a0a0a, #1a0a1a, #0a1a1a, #1a1a0a);
  background-size: 400% 400%;
  animation: rainbowBorder 15s ease infinite;
}

/* フッターのギラギラ効果 */
.footer {
  background: linear-gradient(90deg, rgba(255,0,255,0.2), rgba(0,255,255,0.2), rgba(255,255,0,0.2));
  border-top: 2px solid var(--neon-pink);
  box-shadow: 0 -2px 20px rgba(255,0,255,0.3);
}
