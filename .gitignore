# .gitignore - 自動生成のビルド成果物、依存関係、個人設定、秘密情報を除外

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Node.js
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Build / 出力
dist/
build/
out/
.cache/
.cache-loader/
.parcel-cache/
coverage/

# Cloudflare (Wrangler / Pages)
# wrangler のローカル状態やシークレットなどを含むディレクトリは追跡しない
.wrangler/
.wrangler/*.toml
.wrangler/.secrets
.wrangler/state
.wrangler/dev/
# ローカルで作る一時的な wrangler 設定ファイル
wrangler-local.toml
wrangler.*.toml

# Cloudflare Pages の生成物（プロジェクトによって別名のこともある）
.pages/
.publish/

# 環境変数 / シークレット
.env
.env.*.local
*.key
*.pem
*.secret
secrets.json

# ログ / 一時ファイル
logs/
*.log
tmp/
temp/
*.tmp

# エディタ / IDE
.vscode/
.idea/
*.sublime-workspace
*.sublime-project

# OS / その他
Thumbs.db
ehthumbs.db

# プロジェクト固有（トークン等のローカル保存ファイル）
# 必要に応じてファイル名を追加してください
tokens/
tokens.txt
*.tokens

# 静的サイトビルドなどの成果物（workspaceに合わせて追加）
Documentsite/build/

# Gitの追跡対象から外したい既にコミット済みのファイルがある場合は
# ローカルでgitのキャッシュを削除してください（例: git rm --cached <file>）。

# 履歴や一時ディレクトリ
.history

# 任意: OS / CI のキャッシュやローカル環境ファイル
.cache-loader/
.cargo/

# 参考: Cloudflare にデプロイする際は、機密情報（APIキー/トークン等）を
# リポジトリに含めないでください。wrangler の secret 機能や Pages の環境変数を使用してください。